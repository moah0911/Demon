// Test using a dictionary approach

print("Dictionary Test");

// Create a dictionary
let dict = {"name": "John", "age": 30};

// Access values
print("Name:", dict["name"]);
print("Age:", dict["age"]);

// Create a priority queue
let pq = PriorityQueue();

// Add items
pq["push"]("Task 1", 3);
pq["push"]("Task 2", 1);
pq["push"]("Task 3", 2);

// Process items
print("\nProcessing tasks in priority order:");
while (!pq["is_empty"]()) {
    print(pq["pop"]());
}

print("Test completed!");