// Test for Priority Queue

print("Priority Queue Test");

// Create a priority queue
let pq = PriorityQueue();

// Test if the object was created
print("Priority Queue created:", pq);

// Try to access a method
print("Is empty method exists:", pq.is_empty != nil);

// Try to call a method
print("Is empty:", pq.is_empty());

// Try to add items
print("Adding items...");
pq.push("Task 1", 3);
pq.push("Task 2", 1);
pq.push("Task 3", 2);

// Check if empty after adding
print("Is empty after adding:", pq.is_empty());

// Process items
print("\nProcessing tasks in priority order:");
while (!pq.is_empty()) {
    print(pq.pop());
}

print("Test completed!");