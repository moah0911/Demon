// Comprehensive test of Demon language features

// Basic print statements
print("1. Basic print test");
print("Multiple arguments:", 42, true, nil);

// Variables and arithmetic
print("\n2. Variables and arithmetic");
let x = 10;
let y = 5;
print("x =", x, "y =", y);
print("x + y =", x + y);
print("x - y =", x - y);
print("x * y =", x * y);
print("x / y =", x / y);
print("x % y =", x % y);

// String operations
print("\n3. String operations");
let greeting = "Hello";
let name = "Demon";
print(greeting + ", " + name + "!");
print("String with number:", greeting + " " + 123);

// Boolean operations
print("\n4. Boolean operations");
let a = true;
let b = false;
print("a =", a, "b =", b);
print("a and b =", a and b);
print("a or b =", a or b);
print("not a =", !a);

// Comparison operators
print("\n5. Comparison operators");
print("x > y:", x > y);
print("x >= y:", x >= y);
print("x < y:", x < y);
print("x <= y:", x <= y);
print("x == y:", x == y);
print("x != y:", x != y);

// Conditional statements
print("\n6. Conditional statements");
if (x > y) {
    print("x is greater than y");
} else if (x < y) {
    print("x is less than y");
} else {
    print("x is equal to y");
}

// While loops
print("\n7. While loops");
let counter = 1;
while (counter <= 3) {
    print("Counter:", counter);
    counter = counter + 1;
}

// Lists
print("\n8. Lists");
let numbers = [1, 2, 3, 4, 5];
print("List:", numbers);
// Accessing list elements not supported yet

// Functions
print("\n9. Functions");
func add(a, b) {
    return a + b;
}

print("add(5, 3) =", add(5, 3));

func greet(name) {
    return "Hello, " + name + "!";
}

print(greet("World"));

// Nested blocks and scope
print("\n10. Nested blocks and scope");
let outer = "I'm outer";
{
    let inner = "I'm inner";
    print("Inside block - outer:", outer);
    print("Inside block - inner:", inner);
}
print("Outside block - outer:", outer);
// print("Outside block - inner:", inner); // This would cause an error

// Constants
print("\n11. Constants");
const PI = 3.14159;
print("PI =", PI);
// PI = 3; // This would cause an error

print("\nAll tests completed successfully!");