// Test file for the debugger

// Function to calculate factorial
func factorial(n) {
    if (n <= 1) {
        return 1;
    }
    return n * factorial(n - 1);
}

// Function to calculate fibonacci
func fibonacci(n) {
    if (n <= 0) {
        return 0;
    } else if (n == 1) {
        return 1;
    }
    return fibonacci(n - 1) + fibonacci(n - 2);
}

// Main program
print("Debugger Test Program");
print("--------------------");

// Variables to inspect
let a = 10;
let b = "hello";
let c = [1, 2, 3, 4, 5];

// Loop to set breakpoints
let i = 0;
while (i < 5) {
    print("Loop iteration:", i);
    a = a + i;
    i = i + 1;
}

// Calculate factorial
let n = 5;
let fact = factorial(n);
print("Factorial of", n, "is", fact);

// Calculate fibonacci
let fib = fibonacci(7);
print("Fibonacci(7) =", fib);

// Nested function calls for call stack testing
func level1() {
    print("In level1");
    level2();
}

func level2() {
    print("In level2");
    level3();
}

func level3() {
    print("In level3");
    // Cause an exception for testing exception breakpoints
    let x = 10;
    let y = 0;
    if (y != 0) {
        print(x / y);  // This would cause a division by zero
    }
}

// Call the nested functions
level1();

print("Program completed successfully!");