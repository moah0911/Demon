// Test file for IDE features

// Variables with different types
let name = "Demon";
let age = 1;
let is_active = true;
let scores = [95, 87, 92, 98];

// Function definition
func greet(person_name) {
    return "Hello, " + person_name + "!";
}

// Function with multiple parameters - simplified to avoid array access
func calculate_average(a, b, c, d) {
    let sum = a + b + c + d;
    let count = 4;
    return sum / count;
}

// Class-like structure using functions
func Person(name, age) {
    let person = {};
    person.name = name;
    person.age = age;
    
    person.greet = func() {
        return "Hello, my name is " + person.name;
    };
    
    person.have_birthday = func() {
        person.age = person.age + 1;
        return person.age;
    };
    
    return person;
}

// Main program
print("IDE Test Program");
print("---------------");

// Test function calls
print(greet(name));
print("Average score:", calculate_average(95, 87, 92, 98));

// Test object creation
let alice = Person("Alice", 30);
print(alice.greet());
print("Happy birthday! Alice is now", alice.have_birthday());

// Test control flow
if (age < 18) {
    print("Minor");
} else if (age < 65) {
    print("Adult");
} else {
    print("Senior");
}

// Test loops
print("Counting from 1 to 5:");
let i = 1;
while (i <= 5) {
    print(i);
    i = i + 1;
}

// Test standard library functions - simplified to avoid array operations
print("Original numbers: 4, 2, 8, 5, 1, 3, 7, 6");
