{
  "If Statement": {
    "prefix": "if",
    "body": [
      "if (${1:condition}) {",
      "\t$0",
      "}"
    ],
    "description": "If statement"
  },
  "If-Else Statement": {
    "prefix": "ifelse",
    "body": [
      "if (${1:condition}) {",
      "\t$2",
      "} else {",
      "\t$0",
      "}"
    ],
    "description": "If-else statement"
  },
  "For Loop": {
    "prefix": "for",
    "body": [
      "for (let ${1:i} = ${2:0}; ${1:i} < ${3:length}; ${1:i} = ${1:i} + 1) {",
      "\t$0",
      "}"
    ],
    "description": "For loop"
  },
  "While Loop": {
    "prefix": "while",
    "body": [
      "while (${1:condition}) {",
      "\t$0",
      "}"
    ],
    "description": "While loop"
  },
  "Function Declaration": {
    "prefix": "func",
    "body": [
      "func ${1:name}(${2:parameters}) {",
      "\t$0",
      "}"
    ],
    "description": "Function declaration"
  },
  "Variable Declaration": {
    "prefix": "let",
    "body": [
      "let ${1:name} = ${2:value};"
    ],
    "description": "Variable declaration"
  },
  "Print Statement": {
    "prefix": "print",
    "body": [
      "print(${1:\"Hello, World!\"});"
    ],
    "description": "Print statement"
  },
  "List Declaration": {
    "prefix": "list",
    "body": [
      "let ${1:name} = [${2:items}];"
    ],
    "description": "List declaration"
  },
  "Return Statement": {
    "prefix": "return",
    "body": [
      "return ${1:value};"
    ],
    "description": "Return statement"
  },
  "Comment Block": {
    "prefix": "comment",
    "body": [
      "/*",
      " * ${1:comment}",
      " */"
    ],
    "description": "Comment block"
  },
  "Line Comment": {
    "prefix": "//",
    "body": [
      "// ${1:comment}"
    ],
    "description": "Line comment"
  }
}